@startuml xdbg-overview

left to right direction

skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam defaultFontName "Helvetica"
skinparam defaultFontSize 14
skinparam roundCorner 10
skinparam ArrowColor #37474F
skinparam ArrowFontColor #263238
skinparam package {
  BorderColor #607D8B
  FontStyle bold
  BackgroundColor #FAFAFA
}
skinparam rectangle {
  BackgroundColor #E3F2FD
  BorderColor #1565C0
}
skinparam actor {
  BackgroundColor #ECEFF1
  BorderColor #455A64
}

title xdbg — overview

actor "AI agent\n(Claude Code / opencode)" as agent
rectangle "xdbg\nMCP server\n(stdio)" as xdbg
rectangle "Xdebug\n(DBGp engine)\nin Docker container" as xdebug

agent --> xdbg : "MCP tools\nxdbg_request, xdbg_run_command,\nxdbg_set_breakpoint, xdbg_eval, …"
xdbg --> xdebug : "DBGp\nbreakpoint_set, step, eval\nover TCP :9003"
xdebug --> xdbg : "dials out on every\nHTTP request / CLI command"

@enduml