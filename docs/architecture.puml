@startuml xdbg-architecture

skinparam backgroundColor #FFFFFF
skinparam dpi 150
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true

title xdbg — HTTP request debugging flow

actor "AI agent\n(Claude Code / opencode)" as Agent

box "Host — xdbg (Go binary, MCP stdio)" #E3F2FD
participant MCP as "MCP stdio\n(JSON-RPC)"
participant Core as "xdbg core\n(DBGp state machine)"
participant Listener as "DBGp listener\n0.0.0.0:9003"
end box

box "Container (PHP app)" #E8F5E9
participant Fpm as "php-fpm\n:8080"
participant Script as "PHP script\n(controller / command)"
participant Xdebug as "Xdebug engine\nstart_with_request=yes"
end box

== Setup ==

Agent -> MCP: xdbg_container_enable()
MCP -> Core: dispatch
Core -> Xdebug: set-xdebug-on (shell)
Xdebug --> Core: ok

Agent -> MCP: xdbg_set_breakpoint("src/FooController.php", 42)
MCP -> Core: queue breakpoint

== HTTP request ==

Agent -> MCP: xdbg_request(url, method, headers, body)
MCP -> Core: dispatch
Core -> Listener: open :9003
Core -> Fpm: fire HTTP request\nPOST /api/foo HTTP/1.1\n(method/headers/body)
Fpm -> Script: execute FooController::bar()
Script -> Xdebug: Xdebug hooks fire
Xdebug -> Listener: dial out\nhost.docker.internal:9003
Listener -> Core: adopt connection
Core -> Xdebug: apply breakpoints\nbreakpoint_set FooController.php:42
Core -> Xdebug: run
Xdebug -> Core: break at FooController.php:42

== Debug session ==

Agent -> MCP: xdbg_stack()
MCP -> Core: dispatch
Core -> Xdebug: stack_get
Xdebug --> Core: call stack (host paths)
Core --> Agent: stack frames

Agent -> MCP: xdbg_context(0)
MCP -> Core: dispatch
Core -> Xdebug: context_get -d 0
Xdebug --> Core: variables in scope
Core --> Agent: $user, $request, ...

Agent -> MCP: xdbg_eval("$user->getId()")
MCP -> Core: dispatch
Core -> Xdebug: eval (base64)
Xdebug --> Core: result
Core --> Agent: 12345

Agent -> MCP: xdbg_step_over()
MCP -> Core: dispatch
Core -> Xdebug: step_over
Xdebug --> Core: break at next line
Core --> Agent: state=break location=FooController.php:43

Agent -> MCP: xdbg_run()
MCP -> Core: dispatch
Core -> Xdebug: run
Xdebug --> Core: stopping (script finished)
Core --> Agent: script finished

== Cleanup ==

Agent -> MCP: xdbg_detach()
MCP -> Core: dispatch
Core -> Xdebug: detach
Core -> Listener: close :9003
Core --> Agent: detached

Agent -> MCP: xdbg_container_disable()
MCP -> Core: dispatch
Core -> Xdebug: set-xdebug-off (shell)
Xdebug --> Core: ok

@enduml