flowchart LR
    subgraph host["Host (developer machine)"]
        direction TB
        agent["AI agent<br/>Claude Code / opencode / Cursor"]
        xdbg["xdbg — MCP stdio server (Go binary)<br/>MCP layer + DBGp client<br/>(path translation host→container)"]
        listener["DBGp listener<br/>0.0.0.0:9003"]
        agent -- "MCP tools<br/>xdbg_request, xdbg_set_breakpoint,<br/>xdbg_eval, xdbg_run_command, …" --> xdbg
        xdbg -- "open :9003" --> listener
    end
    class host hostCls

    subgraph container["Docker container"]
        direction TB
        xdebug["Xdebug engine<br/>start_with_request=yes<br/>client_host=host.docker.internal"]
        app["PHP app<br/>controllers, console commands"]
        fpm["php-fpm<br/>web entrypoint"]
        xdebug -- "Xdebug hooks fire" --> app
        app -- "execute script" --> fpm
    end
    class container containerCls

    listener <-.->|"DBGp over TCP :9003<br/>xdbg sends: breakpoint_set, step, eval<br/>Xdebug dials out on every request/command"| xdebug
    xdbg -- "fire HTTP request<br/>(method/headers/body)" --> fpm
    xdbg -- "run_command<br/>(docker compose exec)" --> app

    classDef hostCls fill:#FFF7E0,stroke:#C9A227,stroke-width:1.5px,color:#1A1A1A
    classDef containerCls fill:#E8F3FF,stroke:#3B7DD8,stroke-width:1.5px,color:#1A1A1A

    linkStyle 4,5,6 stroke-dasharray:6,stroke:#3B7DD8
